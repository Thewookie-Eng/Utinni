<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net472</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>UtinniCoreDotNetGen</AssemblyName>
    <RootNamespace>UtinniCoreDotNetGen</RootNamespace>
    <!-- Suppress auto-generated attributes since AssemblyInfo.cs provides them -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>7.3</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="CppSharp">
      <HintPath>..\external\CppSharp\lib\CppSharp.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="CppSharp.AST">
      <HintPath>..\external\CppSharp\lib\CppSharp.AST.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="CppSharp.Generator">
      <HintPath>..\external\CppSharp\lib\CppSharp.Generator.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="CppSharp.Parser">
      <HintPath>..\external\CppSharp\lib\CppSharp.Parser.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="CppSharp.Parser.CLI">
      <HintPath>..\external\CppSharp\lib\CppSharp.Parser.CLI.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
    <Reference Include="CppSharp.Runtime">
      <HintPath>..\external\CppSharp\lib\CppSharp.Runtime.dll</HintPath>
      <SpecificVersion>False</SpecificVersion>
    </Reference>
  </ItemGroup>

  <Target Name="CopyCppSharpNativeDeps" AfterTargets="Build">
    <Exec Command="xcopy /E /Y /D &quot;$(SolutionDir)external\CppSharp\lib&quot; &quot;$(TargetDir)&quot;" />
  </Target>

</Project>
